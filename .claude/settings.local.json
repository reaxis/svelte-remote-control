{
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "svelte"
  ],
  "permissions": {
    "allow": [
      "mcp__svelte__svelte-autofixer"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | { read -r f; [[ \"$f\" == */CLAUDE.md ]] && cp \"$f\" \"$(dirname \"$f\")/AGENTS.md\"; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
